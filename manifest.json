{
    "manifest_version": 3,
    "name": "po-my-doro",
    "version": "1.0.0",
    "description": "A privacy-focused Pomodoro timer with dual modes, audio cues, and rich analytics — all stored locally.",
    "permissions": [
        "storage",
        "alarms",
        "notifications",
        "offscreen"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}